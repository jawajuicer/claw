# The Claw — Environment Variables
# Copy to .env and customize

# LLM server (llama-swap)
CLAW_LLM__BASE_URL=http://localhost:8081/v1
CLAW_LLM__MODEL=qwen2.5:14b

# Audio (leave DEVICE_INDEX commented out for system default)
# CLAW_AUDIO__DEVICE_INDEX=
CLAW_AUDIO__SAMPLE_RATE=16000

# Wake word
CLAW_WAKE__MODEL_PATH=hey_jarvis_v0.1
CLAW_WAKE__THRESHOLD=0.5

# Whisper
CLAW_WHISPER__MODEL_SIZE=base
CLAW_WHISPER__COMPUTE_TYPE=int8

# Admin panel
CLAW_ADMIN__HOST=0.0.0.0
CLAW_ADMIN__PORT=8080

# Memory
CLAW_MEMORY__CHROMA_PATH=data/chromadb
CLAW_MEMORY__EMBEDDING_MODEL=all-MiniLM-L6-v2

# YouTube Music (disabled by default — requires auth setup)
CLAW_YOUTUBE_MUSIC__ENABLED=false
CLAW_YOUTUBE_MUSIC__AUTH_FILE=data/youtube_music/auth.json
