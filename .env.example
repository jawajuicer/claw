# The Claw — Environment Variables
# Copy to .env and customize.
# Priority: env vars > .env > config.yaml > defaults
# Naming: CLAW_<SECTION>__<FIELD> (double underscore separates section from field)


# ── Audio ──────────────────────────────────────────────────────────────────
# CLAW_AUDIO__DEVICE_INDEX=           # leave blank for system default
# CLAW_AUDIO__OUTPUT_DEVICE_INDEX=    # leave blank for system default
CLAW_AUDIO__SAMPLE_RATE=16000
# CLAW_AUDIO__CHANNELS=1
# CLAW_AUDIO__BLOCK_SIZE=1280
# CLAW_AUDIO__SILENCE_DURATION=2.0
# CLAW_AUDIO__AGC_SILENCE_THRESHOLD=0.05
# CLAW_AUDIO__AGC_GAIN_CEILING=3.5
# CLAW_AUDIO__VAD_THRESHOLD=0.5
# CLAW_AUDIO__MAX_RECORD_SECONDS=30
# CLAW_AUDIO__CHIME_ENABLED=true
# CLAW_AUDIO__CHIME_VOLUME=0.5
# CLAW_AUDIO__CHIME_FREQUENCY=880
# CLAW_AUDIO__CHIME_DURATION_MS=200


# ── Wake word ──────────────────────────────────────────────────────────────
# MODEL_PATHS is a list; use JSON array syntax for env vars
# CLAW_WAKE__MODEL_PATHS=["hey_claw_v0.1"]
# CLAW_WAKE__DEFAULT_THRESHOLD=0.5
# CLAW_WAKE__INFERENCE_FRAMEWORK=onnx
# CLAW_WAKE__CUSTOM_MODELS_DIR=data/models/wake


# ── Whisper (STT) ─────────────────────────────────────────────────────────
CLAW_WHISPER__MODEL_SIZE=base
CLAW_WHISPER__COMPUTE_TYPE=int8
# CLAW_WHISPER__LANGUAGE=en
# CLAW_WHISPER__BEAM_SIZE=5


# ── TTS ────────────────────────────────────────────────────────────────────
# CLAW_TTS__ENABLED=true
# CLAW_TTS__ENGINE=piper                # "piper" or "fish_speech"
# CLAW_TTS__PIPER_MODEL=data/models/tts/piper/en_US-lessac-medium.onnx
# CLAW_TTS__PIPER_SPEAKER_ID=
# CLAW_TTS__FISH_SPEECH_URL=http://localhost:8090
# CLAW_TTS__FISH_SPEECH_REFERENCE_AUDIO=
# CLAW_TTS__FISH_SPEECH_REFERENCE_TEXT=
# CLAW_TTS__SPEED=1.0
# CLAW_TTS__VOICE_LOOP_ENABLED=true
# CLAW_TTS__ADMIN_CHAT_ENABLED=true
# CLAW_TTS__ADMIN_CHAT_AUTOPLAY=false
# CLAW_TTS__MUSIC_ANNOUNCEMENT=before   # "before" or "none"


# ── LLM (local via llama-swap) ────────────────────────────────────────────
CLAW_LLM__BASE_URL=http://localhost:8081/v1
CLAW_LLM__MODEL=qwen3.5:4b
# CLAW_LLM__API_KEY=no-key
# CLAW_LLM__FAST_MODEL=               # lighter model for conversational queries
# CLAW_LLM__TEMPERATURE=0.7
# CLAW_LLM__MAX_TOKENS=1024
# CLAW_LLM__MAX_ITERATIONS=5
# CLAW_LLM__CONTEXT_WINDOW=32768
# CLAW_LLM__TIMEOUT=45
# CLAW_LLM__THINKING=off               # "off", "low", "medium", "high"
# CLAW_LLM__COMPACT_THRESHOLD=0.8
# CLAW_LLM__COMPACT_KEEP_RECENT=6
# CLAW_LLM__SYSTEM_PROMPT=You are The Claw, a helpful voice assistant.


# ── Cloud LLM (optional cloud providers) ──────────────────────────────────
# CLAW_CLOUD_LLM__ACTIVE_PROVIDER=local    # "local", "claude", "gemini"
# CLAW_CLOUD_LLM__FAILOVER_TO_LOCAL=true
# CLAW_CLOUD_LLM__FAILOVER_CHAIN=          # comma-separated, e.g. "claude,local"


# ── Compute ────────────────────────────────────────────────────────────────
# CLAW_COMPUTE__BACKEND=cpu             # "cpu", "cuda", "rocm", "vulkan"
# CLAW_COMPUTE__GPU_LAYERS=99


# ── Memory (ChromaDB) ─────────────────────────────────────────────────────
CLAW_MEMORY__CHROMA_PATH=data/chromadb
CLAW_MEMORY__EMBEDDING_MODEL=all-MiniLM-L6-v2
# CLAW_MEMORY__MAX_RESULTS=5
# CLAW_MEMORY__CONVERSATION_COLLECTION=conversations
# CLAW_MEMORY__FACTS_COLLECTION=facts
# CLAW_MEMORY__CATEGORIES_COLLECTION=categories


# ── MCP (tool servers) ────────────────────────────────────────────────────
# CLAW_MCP__TOOLS_DIR=mcp_tools
# CLAW_MCP__STARTUP_TIMEOUT=10
# CLAW_MCP__ENABLED_SERVERS=youtube_music,system_control,notes,local_calendar,google_calendar,gmail
# CLAW_MCP__VOICE_SERVERS=system_control


# ── Scheduler ──────────────────────────────────────────────────────────────
# CLAW_SCHEDULER__ENABLED=true
# CLAW_SCHEDULER__POLL_INTERVAL=30
# CLAW_SCHEDULER__ANNOUNCE_TTS=true


# ── Weather ────────────────────────────────────────────────────────────────
# CLAW_WEATHER__API_KEY=                # OpenWeatherMap API key (free tier)
# CLAW_WEATHER__DEFAULT_LOCATION=       # e.g. "Akron, OH"


# ── Gemini ─────────────────────────────────────────────────────────────────
# CLAW_GEMINI__ENABLED=false
# CLAW_GEMINI__MODEL=gemini-2.5-flash
# CLAW_GEMINI__PRO_MODEL=gemini-2.5-pro
# CLAW_GEMINI__TEMPERATURE=0.7
# CLAW_GEMINI__MAX_OUTPUT_TOKENS=2048
# CLAW_GEMINI__WEB_SEARCH=true
# CLAW_GEMINI__DOCUMENT_ANALYSIS=true
# CLAW_GEMINI__IMAGE_UNDERSTANDING=true
# CLAW_GEMINI__REASONING_FALLBACK=false
# CLAW_GEMINI__ESCALATION_MODE=ask     # "ask", "auto", "off"
# CLAW_GEMINI__DAILY_REQUEST_LIMIT=200
# CLAW_GEMINI__GROUNDING_DAILY_LIMIT=400
# CLAW_GEMINI__LOG_REQUESTS=true
# CLAW_GEMINI__LOG_DIR=data/gemini/logs


# ── YouTube Music ──────────────────────────────────────────────────────────
CLAW_YOUTUBE_MUSIC__ENABLED=false
CLAW_YOUTUBE_MUSIC__AUTH_FILE=data/youtube_music/auth.json
# CLAW_YOUTUBE_MUSIC__HISTORY_FILE=data/youtube_music/history.json
# CLAW_YOUTUBE_MUSIC__PINS_FILE=data/youtube_music/pins.json
# CLAW_YOUTUBE_MUSIC__AUTO_RADIO=true
# CLAW_YOUTUBE_MUSIC__DEFAULT_VOLUME=80
# CLAW_YOUTUBE_MUSIC__MAX_HISTORY=500
# CLAW_YOUTUBE_MUSIC__MAX_SEARCH_RESULTS=5


# ── Notes ──────────────────────────────────────────────────────────────────
# CLAW_NOTES__ENABLED=true
# CLAW_NOTES__STORAGE_DIR=data/notes
# CLAW_NOTES__MAX_NOTES=0              # 0 = unlimited


# ── Local Calendar ─────────────────────────────────────────────────────────
# CLAW_LOCAL_CALENDAR__ENABLED=true
# CLAW_LOCAL_CALENDAR__STORAGE_FILE=data/calendar/local.json


# ── Google Auth (multi-account) ───────────────────────────────────────────
# CLAW_GOOGLE_AUTH__CREDENTIALS_FILE=data/google/credentials.json
# Per-account config is complex (nested dict) — use config.yaml for Google accounts


# ── Chat ───────────────────────────────────────────────────────────────────
# CLAW_CHAT__SAVE_CONVERSATIONS=false
# CLAW_CHAT__CONVERSATIONS_DIR=data/conversations
# CLAW_CHAT__SESSION_TIMEOUT=86400     # seconds (default 24h)


# ── Admin panel ────────────────────────────────────────────────────────────
CLAW_ADMIN__HOST=0.0.0.0
CLAW_ADMIN__PORT=8080
# CLAW_ADMIN__LOG_BUFFER_SIZE=1000
# CLAW_ADMIN__LOG_FORMAT=text           # "text" or "json"
# CLAW_ADMIN__LOG_FILE=                 # path to log file; empty = stdout only
# CLAW_ADMIN__AUTH_ENABLED=true
# CLAW_ADMIN__AUTH_USERNAME=admin


# ── Remote / WireGuard (Android app) ──────────────────────────────────────
# CLAW_REMOTE__ENABLED=false
# CLAW_REMOTE__AUDIO_OUTPUT=phone       # "phone" or "computer"
# CLAW_REMOTE__WG_INTERFACE=wg0
# CLAW_REMOTE__WG_SUBNET=10.10.0
# CLAW_REMOTE__WG_PORT=51820
# CLAW_REMOTE__WG_ENDPOINT=             # public IP or hostname


# ── Webhook ────────────────────────────────────────────────────────────────
# CLAW_WEBHOOK__ENABLED=false
# CLAW_WEBHOOK__SECRET=                 # HMAC-SHA256 secret; empty = no verification
# CLAW_WEBHOOK__ALLOWED_EVENTS=message,reminder,notification


# ── Usage tracking ────────────────────────────────────────────────────────
# CLAW_USAGE__ENABLED=true
# CLAW_USAGE__PERSIST_FILE=data/usage.json
# CLAW_USAGE__PERSIST_INTERVAL=60      # seconds
